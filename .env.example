# 飞书自建应用凭证 (开放平台 -> 凭证与基础信息)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 目标多维表格 (从表格URL中获取: https://xxx.feishu.cn/base/{app_token}?table={table_id})
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=

# Cookie失效等异常提醒用的飞书群机器人 Webhook
FEISHU_ALERT_WEBHOOK=

# 知识星球登录 Cookie（从浏览器登录 wx.zsxq.com 后，F12 -> 网络 -> 任意 api.zsxq.com 请求的 Cookie 请求头中复制）
ZSXQ_COOKIE=

# 要抓取的知识星球群组，格式：群组ID:显示名称，多个用逗号分隔
ZSXQ_GROUPS=552521142424:姜胡说,458522225218:珍大户的经济圈
